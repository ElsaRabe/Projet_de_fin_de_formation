# Environnement virtuel
venv/
env/
.venv/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# Données collectées (volumineuses, propres à chaque utilisateur)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/external/*
!data/external/.gitkeep

# Modèles entraînés (volumineux, régénérables via train.py)
models/*
!models/.gitkeep

# Streamlit
.streamlit/

# IDE / éditeurs
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log